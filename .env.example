PORT=8787
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:55432/codeguard
REDIS_URL=redis://127.0.0.1:6379
SCAN_QUEUE_NAME=codeguard_scans
ADMIN_KEY=codeguard-dev-admin
SCAN_TIMEOUT_MS=60000
MAX_REPO_SIZE_KB=50000
REQUIRED_SCANNERS=gitleaks,semgrep,osv-scanner
VITE_ADMIN_KEY=codeguard-dev-admin
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=info
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=codeguard-dev-session-secret
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8787/auth/github/callback

# Optional local LLM summary (Ollama)
# OLLAMA_MODEL=qwen2.5-coder:7b
# OLLAMA_URL=http://127.0.0.1:11434

# Optional GitHub token to reduce API rate-limit issues on repo scanning
# GITHUB_TOKEN=ghp_xxx
